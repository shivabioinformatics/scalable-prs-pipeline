/*
 * nextflow.config — Pipeline configuration
 *
 * All the knobs I can turn without editing the actual pipeline code.
 * The params block has defaults that work for the demo data.
 * In production, you'd override these on the command line or with
 * a custom config file.
 *
 * I set up three profiles:
 *   - local: runs on my laptop, no containers
 *   - docker: wraps each step in a container (more reproducible)
 *   - aws_batch: runs on AWS with spot instances (the cloud architecture)
 */

// ---- default parameters ----
params {
    // input files
    input_vcf    = "${projectDir}/data/sample_input.vcf"
    gwas_stats   = "${projectDir}/data/gwas_summary_stats.tsv"
    ref_panel    = "${projectDir}/data/reference_panel.vcf"
    chain_file   = "${projectDir}/data/chain_file.chain"

    // output
    outdir       = "${projectDir}/results"

    // QC thresholds — these are standard cutoffs from the PRS literature
    min_call_rate     = 0.95
    min_maf           = 0.01
    min_depth         = 10
    min_sample_call_rate = 0.90

    // PRS settings
    p_threshold  = 0.05        // only include variants with p < this
    genome_build = "hg38"      // target genome build for normalization

    // AWS settings (only used with -profile aws_batch)
    aws_queue    = "prs-job-queue"
    aws_region   = "us-east-1"
    s3_bucket    = "s3://prs-pipeline-data"
}

// ---- execution profiles ----
profiles {
    local {
        // running on my laptop — no containers, just use whatever's installed
        process.executor = 'local'
        docker.enabled = false
    }

    docker {
        // containerized — each process gets its own image
        // this is the right way to do it for reproducibility
        docker.enabled = true
        process.container = 'python:3.11-slim'
    }

    aws_batch {
        /*
         * AWS Batch profile — this is the cloud architecture from my design doc.
         *
         * How it works:
         * 1. Upload VCF to S3 input bucket
         * 2. S3 event triggers a Lambda function
         * 3. Lambda starts this Nextflow pipeline via AWS Batch
         * 4. Batch spins up EC2 instances (spot for imputation to save $$$)
         * 5. Results go back to S3 + scores go to the database
         * 6. EC2 instances shut down when done — no idle costs
         *
         * The spot instance config is key for cost control:
         * imputation is the most compute-heavy step, and spot instances
         * are 60-90% cheaper than on-demand. The tradeoff is they can
         * be interrupted, but Nextflow handles retries automatically.
         */
        process.executor = 'awsbatch'
        process.queue = params.aws_queue
        aws.region = params.aws_region
        aws.batch.cliPath = '/home/ec2-user/miniconda/bin/aws'

        // S3 as the work directory — all intermediate files go here
        workDir = "${params.s3_bucket}/work"

        docker.enabled = true
        process.container = 'python:3.11-slim'
    }
}

/*
 * S3 Lifecycle Rules & Archiving Strategy
 * ----------------------------------------
 * This is something the feedback said I should discuss more.
 *
 * In production, I'd configure S3 lifecycle rules on the output bucket:
 *
 * 1. STANDARD tier (0-30 days): results are hot, clinicians are actively reviewing
 * 2. STANDARD_IA (30-90 days): infrequent access, still quick retrieval
 * 3. GLACIER (90+ days): archived, takes hours to retrieve but very cheap
 * 4. DEEP_ARCHIVE (365+ days): long-term compliance storage, pennies per GB
 *
 * For HIPAA compliance, patient genomic data needs to be retained for
 * at least 6 years. Glacier Deep Archive keeps costs below $1/TB/month
 * for that retention period.
 *
 * To implement this, I'd add an S3 lifecycle policy JSON to the bucket:
 * {
 *   "Rules": [{
 *     "ID": "ArchivePRSResults",
 *     "Filter": {"Prefix": "results/"},
 *     "Transitions": [
 *       {"Days": 30, "StorageClass": "STANDARD_IA"},
 *       {"Days": 90, "StorageClass": "GLACIER"},
 *       {"Days": 365, "StorageClass": "DEEP_ARCHIVE"}
 *     ],
 *     "Status": "Enabled"
 *   }]
 * }
 */

// ---- resource config ----
includeConfig 'conf/resources.config'

// ---- reports ----
// nextflow generates these automatically — super useful for debugging
timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_timeline.html"
}
report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/pipeline_report.html"
}

// ---- manifest ----
manifest {
    name            = 'prs-pipeline'
    author          = 'Bioinformatics Final Project'
    description     = 'Scalable Polygenic Risk Score calculation pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version         = '1.0.0'
}
