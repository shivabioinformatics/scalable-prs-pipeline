/*
 * resources.config — Per-process resource allocation
 *
 * Imputation is by far the most expensive step — that's where the
 * spot instances really pay off. Scoring is lighter but still benefits
 * from some memory since I'm loading the full genotype matrix.
 *
 * For the demo data these are overkill, but they're sized for a real
 * dataset with ~1M variants and ~10K samples.
 */

process {
    // default: small tasks
    cpus = 2
    memory = '4 GB'
    time = '1h'

    // QC is lightweight — just counting alleles
    withName: 'QC_VCF' {
        cpus = 2
        memory = '4 GB'
        time = '30m'
    }

    // normalization / liftover — I/O bound more than CPU
    withName: 'NORMALIZE_VCF' {
        cpus = 2
        memory = '4 GB'
        time = '30m'
    }

    // imputation is the beast — Beagle loves RAM and cores
    // using spot instances here saves 60-90% on AWS
    withName: 'IMPUTE_GENOTYPES' {
        cpus = 8
        memory = '16 GB'
        time = '4h'
        // in the aws_batch profile, this would use spot instances
        // the retry strategy handles spot interruptions:
        maxRetries = 3
        errorStrategy = 'retry'
    }

    // PRS scoring — needs to hold the genotype matrix in memory
    withName: 'CALCULATE_PRS' {
        cpus = 4
        memory = '8 GB'
        time = '1h'
    }

    // database insertion — lightweight
    withName: 'STORE_RESULTS' {
        cpus = 1
        memory = '2 GB'
        time = '15m'
    }

    // visualization — matplotlib can be slow for big plots
    withName: 'VISUALIZE_PRS' {
        cpus = 2
        memory = '4 GB'
        time = '30m'
    }
}
